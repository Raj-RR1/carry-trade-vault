# ─── Step 1: Deploy ─────────────────────────────────────────────────────────
# MetaMask private key (without 0x prefix works too)
PRIVATE_KEY=0xYourPrivateKeyHere

# ─── Step 2: Generate call bytes (after deploy) ────────────────────────────
# 32-byte substrate account of the vault = contractAddress + 0xEE * 12
# Use: npx ts-node scripts/evmToSubstrate.ts 0xYourContractAddress
VAULT_SUBSTRATE_ACCOUNT=0x0000000000000000000000000000000000000000eeeeeeeeeeeeeeeeeeeeeeee

# DOT amounts for call bytes (in planck, 10 decimals). 1 DOT = 10_000_000_000
# Must account for XCM fee deduction: 0.01 DOT = 100_000_000 planck per destination
#
# Example with 3 DOT deposit, 30% hedge ratio:
#   Bifrost:   2.1 DOT - 0.01 = 2.09 DOT = 20900000000
#   Hydration: 0.9 DOT - 0.01 = 0.89 DOT =  8900000000
BIFROST_DOT_PLANCK=20900000000
HYDRATION_DOT_PLANCK=8900000000

# ─── Step 3: Set call templates (output of generateCallBytes.ts) ───────────
BIFROST_MINT_CALL=0x...
HYDRATION_ROUTER_SELL_CALL=0x...

# ─── AssetHub sovereign account on Bifrost/Hydration ───────────────────────
# blake2_256("sibl" ++ LE_encode(1000)) — same for all sibling parachains
ASSET_HUB_SOVEREIGN=0x...
